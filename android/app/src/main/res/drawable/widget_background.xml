<?xml version="1.0" encoding="utf-8"?>
<!--
  Widget background — soft gradient, large rounded corners.
  Corner radius is overridden in values-v31/dimens.xml to track the system
  widget radius so DTWG matches the launcher's M3 widget chrome on Android 12+.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="135"
        android:startColor="@color/widget_bg_start"
        android:endColor="@color/widget_bg_end" />
    <corners android:radius="@dimen/widget_corner" />
</shape>
